@model WebBattler.Models.Admin.SessionManagementViewModel
@{
    ViewData["Title"] = "Управление сессией";
}

<div class="admin-page">
    <section class="admin-hero card shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-1">Сессия: @Model.SessionName</h1>
                <p class="text-muted mb-0">Настройка стран, карты, шаблонов и армий для ВПИ.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
        </div>
    </section>

    @if (TempData["StatusMessage"] is string status)
    {
        <div class="alert alert-info">@status</div>
    }

    <div class="row g-4 align-items-start">
        <div class="col-lg-5">
            <section class="card shadow-sm mb-4 sticky-lg-top country-panel">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Страны в сессии</h2>
                        <span class="badge text-bg-primary">@Model.Countries.Count()</span>
                    </div>

                    @if (Model.Countries.Any())
                    {
                        <div class="country-list d-grid gap-2">
                            @foreach (var country in Model.Countries)
                            {
                                var provinces = country.Provinces;
								var cities = provinces.SelectMany(p => p.Cities).ToList();
                                <button type="button"
                                        class="btn btn-outline-dark text-start country-card"
                                        data-bs-toggle="modal"
                                        data-bs-target="#countryModal-@country.Name.Replace(" ", "-")">
                                    <div class="fw-semibold">@country.Name</div>
                                    <div class="small text-muted">Провинций: @provinces.Count • Городов: @cities.Count • Казна: @country.Money</div>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">В этой сессии пока нет стран.</p>
                    }
                </div>
            </section>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm mb-4"><div class="card-body">
                <h2 class="h5">Страна</h2>
                <form asp-action="CreateCountry" asp-route-sessionId="@Model.SessionId" method="post">
                    @Html.AntiForgeryToken()
                    <input class="form-control mb-2" name="Name" placeholder="Название" required />
                    <input class="form-control mb-2" name="OwnerId" placeholder="OwnerId" type="number" required />
                    <input class="form-control mb-2" name="Money" placeholder="Стартовые деньги" type="number" />
                    <textarea class="form-control mb-2" name="Description" placeholder="Описание"></textarea>
                    <button class="btn btn-primary w-100" type="submit">Создать страну</button>
                </form>
            </div></div>

            <div class="card shadow-sm mb-4"><div class="card-body">
                <h2 class="h5">Провинция и соседи</h2>
                <form asp-action="CreateProvince" asp-route-sessionId="@Model.SessionId" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input class="form-control mb-2" name="Name" placeholder="Название провинции" required />
                    <input class="form-control mb-2" name="OwnerId" placeholder="OwnerId" type="number" required />
                    <select class="form-select mb-2" name="CountryName" required>
                        <option value="">Страна</option>
                        @foreach (var country in Model.Countries) { <option value="@country.Name">@country.Name</option> }
                    </select>
                    <textarea class="form-control mb-2" name="Description" placeholder="Описание"></textarea>
                    <button class="btn btn-primary w-100" type="submit">Создать провинцию</button>
                </form>

                <form asp-action="AddNeighbour" asp-route-sessionId="@Model.SessionId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-2">
                        <div class="col">
                            <select class="form-select" name="ProvinceName" required>
                                <option value="">Провинция</option>
                                @foreach (var province in Model.Provinces) { <option value="@province.Name">@province.Name</option> }
                            </select>
                        </div>
                        <div class="col">
                            <select class="form-select" name="NeighbourName" required>
                                <option value="">Сосед</option>
                                @foreach (var province in Model.Provinces) { <option value="@province.Name">@province.Name</option> }
                            </select>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary w-100 mt-2" type="submit">Связать соседей</button>
                </form>
            </div></div>

           <div class="card shadow-sm mb-4"><div class="card-body">
                <h2 class="h5">Город</h2>
                <form asp-action="CreateCity" asp-route-sessionId="@Model.SessionId" method="post">
                    @Html.AntiForgeryToken()
                    <input class="form-control mb-2" name="Name" placeholder="Название" required />
                    <input class="form-control mb-2" name="OwnerId" placeholder="OwnerId" type="number" required />
                    <select class="form-select mb-2" name="ProvinceName" required>
                        <option value="">Провинция</option>
                        @foreach (var province in Model.Provinces) { <option value="@province.Name">@province.Name</option> }
                    </select>
                    <div class="row g-2 mb-2">
                        <div class="col"><input class="form-control" name="Population" type="number" placeholder="Население" required /></div>
                        <div class="col"><input class="form-control" name="Level" type="number" placeholder="Уровень" required /></div>
                    </div>
                    <textarea class="form-control mb-2" name="Description" placeholder="Описание"></textarea>
                    <div class="form-check mb-2"><input class="form-check-input" type="checkbox" name="IsCapital" value="true" /><label class="form-check-label">Столица</label></div>
                    <button class="btn btn-primary w-100" type="submit">Создать город</button>
                </form>
            </div></div>

            <div class="card shadow-sm mb-4"><div class="card-body">
                <h2 class="h5">Шаблоны</h2>
                <h3 class="h6 text-muted form-section-title">Создание шаблона юнита</h3>
                <form asp-action="CreateUnitSample" asp-route-sessionId="@Model.SessionId" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input class="form-control mb-2" name="Name" placeholder="Шаблон юнита" required />
                    <input class="form-control mb-2" name="OwnerId" type="number" placeholder="OwnerId" required />
                    <select class="form-select mb-2" name="CountryName" required>
                        <option value="">Страна</option>
                        @foreach (var country in Model.Countries) { <option value="@country.Name">@country.Name</option> }
                    </select>
                    <div class="row g-2 mb-2">
                        <div class="col"><input class="form-control" name="Health" type="number" step="0.1" placeholder="HP" required /></div>
                        <div class="col"><input class="form-control" name="Cost" type="number" placeholder="Стоимость" required /></div>
                    </div>
                    <input class="form-control mb-2" name="Weapon" placeholder="Оружие" required />
                    <input class="form-control mb-2" name="BuildTurns" type="number" placeholder="Ходы строительства" required />
                    <button class="btn btn-outline-primary w-100" type="submit">Создать шаблон юнита</button>
                </form>

                <h3 class="h6 text-muted form-section-title">Создание шаблона здания</h3>
                <form asp-action="CreateBuildingSample" asp-route-sessionId="@Model.SessionId" method="post">
                    @Html.AntiForgeryToken()
                    <input class="form-control mb-2" name="Name" placeholder="Шаблон здания" required />
                    <input class="form-control mb-2" name="OwnerId" type="number" placeholder="OwnerId" required />
                    <select class="form-select mb-2" name="CountryName" required>
                        <option value="">Страна</option>
                        @foreach (var country in Model.Countries) { <option value="@country.Name">@country.Name</option> }
                    </select>
                    <div class="row g-2 mb-2">
                        <div class="col"><input class="form-control" name="Level" type="number" placeholder="Уровень" required /></div>
                        <div class="col"><input class="form-control" name="Cost" type="number" placeholder="Стоимость" required /></div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col"><input class="form-control" name="Income" type="number" placeholder="Доход" required /></div>
                        <div class="col"><input class="form-control" name="BuildTurns" type="number" placeholder="Ходы" required /></div>
                    </div>
                    <textarea class="form-control mb-2" name="Description" placeholder="Описание"></textarea>
                    <button class="btn btn-outline-primary w-100" type="submit">Создать шаблон здания</button>
                </form>
            </div></div>

            <div class="card shadow-sm mb-4"><div class="card-body">
                <h2 class="h5">Армии и юниты</h2>
                <h3 class="h6 text-muted form-section-title">Создание армии</h3>
                <form asp-action="CreateArmy" asp-route-sessionId="@Model.SessionId" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input class="form-control mb-2" name="Name" placeholder="Название армии" required />
                    <input class="form-control mb-2" name="OwnerId" type="number" placeholder="OwnerId" required />
                    <select class="form-select mb-2" name="CountryName" required>
                        <option value="">Страна</option>
                        @foreach (var country in Model.Countries) { <option value="@country.Name">@country.Name</option> }
                    </select>
                    <select class="form-select mb-2" name="ProvinceName" required>
                        <option value="">Провинция</option>
                        @foreach (var province in Model.Provinces) { <option value="@province.Name">@province.Name</option> }
                    </select>
                    <select class="form-select mb-2" name="CityName">
                        <option value="">(опционально) Город</option>
                        @foreach (var city in Model.Cities) { <option value="@city.Name">@city.Name</option> }
                    </select>
                    <select class="form-select mb-2" name="ParentName">
                        <option value="">(опционально) Родительская армия</option>
                        @foreach (var army in Model.Armies) { <option value="@army.Name">@army.Name</option> }
                    </select>
                    <button class="btn btn-primary w-100" type="submit">Создать армию</button>
                </form>

                <h3 class="h6 text-muted form-section-title">Подготовка юнитов</h3>
                <form asp-action="CreateUnit" asp-route-sessionId="@Model.SessionId" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input class="form-control mb-2" name="OwnerId" type="number" placeholder="OwnerId" required />
                    <select class="form-select mb-2" name="SampleName" required>
                        <option value="">Шаблон юнита</option>
                        @foreach (var sample in Model.UnitSamples) { <option value="@sample.Name">@sample.Name</option> }
                    </select>
                    <select class="form-select mb-2" name="ArmyName" required>
                        <option value="">Армия</option>
                        @foreach (var army in Model.Armies) { <option value="@army.Name">@army.Name</option> }
                    </select>
                    <input class="form-control mb-2" name="Quantity" type="number" min="1" value="1" placeholder="Количество" required />
                    <button class="btn btn-primary w-100" type="submit">Запустить подготовку юнитов</button>
                </form>

                <h3 class="h6 text-muted form-section-title">Строительство зданий</h3>
                <form asp-action="CreateBuilding" asp-route-sessionId="@Model.SessionId" method="post">
                    @Html.AntiForgeryToken()
                    <input class="form-control mb-2" name="OwnerId" type="number" placeholder="OwnerId" required />
                    <select class="form-select mb-2" name="SampleName" required>
                        <option value="">Шаблон здания</option>
                        @foreach (var sample in Model.BuildingSamples) { <option value="@sample.Name">@sample.Name</option> }
                    </select>
                    <select class="form-select mb-2" name="CityName" required>
                        <option value="">Город</option>
                        @foreach (var city in Model.Cities) { <option value="@city.Name">@city.Name</option> }
                    </select>
                    <input class="form-control mb-2" name="Quantity" type="number" min="1" value="1" placeholder="Количество" required />
                    <button class="btn btn-outline-primary w-100" type="submit">Запустить строительство</button>
                </form>
            </div></div>
        </div>
    </div>
</div>

@foreach (var country in Model.Countries)
{
    var provinces = country.Provinces;
    var countryArmies = Model.Armies.Where(a => string.Equals(a.Country?.Name, country.Name, StringComparison.OrdinalIgnoreCase) || a.OwnerId == country.OwnerId && a.Country == country).ToList();
    var countryUnitSamples = Model.UnitSamples.Where(s => string.Equals(s.Country?.Name, country.Name, StringComparison.OrdinalIgnoreCase) || s.OwnerId == country.OwnerId && s.Country == country).ToList();
    var countryBuildingSamples = Model.BuildingSamples.Where(s => string.Equals(s.Country?.Name, country.Name, StringComparison.OrdinalIgnoreCase) || s.OwnerId == country.OwnerId && s.Country == country).ToList();

    <div class="modal fade" id="countryModal-@country.Name.Replace(" ", "-")" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title h5 mb-0">@country.Name</h3>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2 mb-3 country-meta">
                        <div class="col-sm-4"><div class="border rounded p-2"><div class="text-muted small">OwnerId</div><div class="fw-semibold">@country.OwnerId</div></div></div>
                        <div class="col-sm-4"><div class="border rounded p-2"><div class="text-muted small">Казна</div><div class="fw-semibold">@country.Money</div></div></div>
                        <div class="col-sm-4"><div class="border rounded p-2"><div class="text-muted small">Провинций</div><div class="fw-semibold">@provinces.Count</div></div></div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(country.Description))
                    {
                        <p class="mb-3"><strong>Описание:</strong> @country.Description</p>
                    }

                    <h4 class="h6">Провинции и города</h4>
                    @if (provinces.Any())
                    {
                        <div class="accordion" id="provinceAccordion-@country.Name.Replace(" ", "-")">
                            @for (var i = 0; i < provinces.Count; i++)
                            {
                                var province = provinces[i];
                                var cities = province.Cities;
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="heading-@country.Name.Replace(" ", "-")-@i">
                                        <button class="accordion-button @(i == 0 ? string.Empty : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@country.Name.Replace(" ", "-")-@i">
                                            @province.Name
                                        </button>
                                    </h2>
                                    <div id="collapse-@country.Name.Replace(" ", "-")-@i" class="accordion-collapse collapse @(i == 0 ? "show" : string.Empty)" data-bs-parent="#provinceAccordion-@country.Name.Replace(" ", "-")">
                                        <div class="accordion-body">
                                            @if (!string.IsNullOrWhiteSpace(province.Description))
                                            {
                                                <p class="mb-2"><strong>Описание:</strong> @province.Description</p>
                                            }
                                            <p class="mb-2 small text-muted">Соседи: @(province.Neighbours != null && province.Neighbours.Any() ? string.Join(", ", province.Neighbours.Select(n => n.Name)) : "не заданы")</p>
                                            @if (cities.Any())
                                            {
                                                <div class="accordion" id="cityAccordion-@country.Name.Replace(" ", "-")-@i">
                                                    @for (var cityIndex = 0; cityIndex < cities.Count; cityIndex++)
                                                    {
                                                        var city = cities[cityIndex];
                                                        <div class="accordion-item">
                                                            <h2 class="accordion-header" id="city-heading-@country.Name.Replace(" ", "-")-@i-@cityIndex">
                                                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#city-collapse-@country.Name.Replace(" ", "-")-@i-@cityIndex">
                                                                    @city.Name @(city.IsCapital ? "(Столица)" : string.Empty)
                                                                </button>
                                                            </h2>
                                                            <div id="city-collapse-@country.Name.Replace(" ", "-")-@i-@cityIndex" class="accordion-collapse collapse" data-bs-parent="#cityAccordion-@country.Name.Replace(" ", "-")-@i">
                                                                <div class="accordion-body">
                                                                    <div class="small text-muted mb-2">Население: @city.Population • Уровень: @city.Level</div>
                                                                    @if (!string.IsNullOrWhiteSpace(city.Description))
                                                                    {
                                                                        <p class="small mb-2">@city.Description</p>
                                                                    }

                                                                    <div class="small fw-semibold mb-1">Строения в городе</div>
                                                                    @if (city.Buildings != null && city.Buildings.Any())
                                                                    {
                                                                        <ul class="list-group list-group-flush">
                                                                            @foreach (var building in city.Buildings)
                                                                            {
                                                                                <li class="list-group-item px-0">
                                                                                    <div class="fw-semibold">@building.Name</div>
                                                                                    <div class="small text-muted">Уровень: @building.Level • Доход: @building.Profit</div>
                                                                                    @if (!string.IsNullOrWhiteSpace(building.Description))
                                                                                    {
                                                                                        <div class="small">@building.Description</div>
                                                                                    }
                                                                                </li>
                                                                            }
                                                                        </ul>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p class="text-muted mb-0">В городе пока нет строений.</p>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <p class="text-muted mb-0">Города отсутствуют.</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Провинции отсутствуют.</p>
                    }

                    <h4 class="h6 mt-4">Армии</h4>
                    @if (countryArmies.Any())
                    {
                        <div class="accordion" id="armyAccordion-@country.Name.Replace(" ", "-")">
                            @for (var i = 0; i < countryArmies.Count; i++)
                            {
                                var army = countryArmies[i];
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="army-heading-@country.Name.Replace(" ", "-")-@i">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#army-collapse-@country.Name.Replace(" ", "-")-@i">
                                            @army.Name
                                        </button>
                                    </h2>
                                    <div id="army-collapse-@country.Name.Replace(" ", "-")-@i" class="accordion-collapse collapse" data-bs-parent="#armyAccordion-@country.Name.Replace(" ", "-")">
                                        <div class="accordion-body">
                                            <p class="small text-muted mb-2">Юнитов: @army.Units.Count • Провинция: @army.Province.Name</p>
                                            @if (army.Units.Any())
                                            {
                                                <ul class="list-group list-group-flush">
                                                    @foreach (var unit in army.Units)
                                                    {
                                                        <li class="list-group-item px-0">
                                                            <div class="fw-semibold">@unit.Name</div>
                                                            <div class="small text-muted">HP: @unit.Health • Оружие: @unit.Weapon</div>
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                            else
                                            {
                                                <p class="text-muted mb-0">В армии пока нет юнитов.</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="mb-2">Нет армий</p>
                    }

                    <h4 class="h6 mt-3">Шаблоны юнитов</h4>
                    <p class="mb-2">@((countryUnitSamples.Any()) ? string.Join(", ", countryUnitSamples.Select(s => s.Name)) : "Нет шаблонов")</p>

                    <h4 class="h6 mt-3">Шаблоны зданий</h4>
                    <p class="mb-0">@((countryBuildingSamples.Any()) ? string.Join(", ", countryBuildingSamples.Select(s => s.Name)) : "Нет шаблонов")</p>
                </div>
            </div>
        </div>
    </div>
}