@model WebBattler.Models.Admin.AdminDashboardViewModel
@{
    ViewData["Title"] = "Админ-панель";
}

<div class="admin-page">
    <section class="admin-hero card shadow-sm mb-4">
        <div class="card-body">
            <h1 class="h3 mb-2">Управление Discord-сессиями</h1>
            <p class="text-muted mb-0">Создавайте игровые сессии, переключайте их активность и управляйте ходами прямо из веб-интерфейса.</p>
        </div>
    </section>

    @if (TempData["StatusMessage"] is string status)
    {
        <div class="alert alert-info">@status</div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <section class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Новая сессия</h2>
                    <form asp-controller="Admin" asp-action="CreateSession" method="post" class="mt-3">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="CreateForm.GuildId" class="form-label">ID Discord сервера</label>
                            <input asp-for="CreateForm.GuildId" class="form-control" />
                            <span asp-validation-for="CreateForm.GuildId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CreateForm.Name" class="form-label">Название сессии</label>
                            <input asp-for="CreateForm.Name" class="form-control" />
                            <span asp-validation-for="CreateForm.Name" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Создать / обновить</button>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-lg-8">
            <section class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Сессии</h2>
                        <span class="badge bg-secondary">@Model.Sessions.Count шт.</span>
                    </div>

                    @if (!Model.Sessions.Any())
                    {
                        <p class="text-muted mb-0">Пока нет ни одной сессии.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Guild ID</th>
                                    <th>Год / ход</th>
                                    <th>Статус</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var session in Model.Sessions)
                                {
                                    <tr>
                                        <td class="fw-semibold">@session.Name</td>
                                        <td>@session.GuildId</td>
                                        <td>@session.CurrentYear / @session.CurrentTurn</td>
                                        <td>
                                            <span class="badge @(session.IsActive ? "bg-success" : "bg-secondary")">
                                                @(session.IsActive ? "Активна" : "Остановлена")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2 justify-content-end">
                                                <a asp-controller="Admin" asp-action="Session" asp-route-id="@session.Id" class="btn btn-sm btn-outline-secondary">Управление</a>
                                                <form asp-controller="Admin" asp-action="AdvanceTurn" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@session.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-primary" @(session.IsActive ? "" : "disabled")>Следующий ход</button>
                                                </form>

                                                 <form asp-controller="Admin" asp-action="ToggleSession" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@session.Id" />
                                                    <button type="submit" class="btn btn-sm @(session.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                                        @(session.IsActive ? "Остановить" : "Запустить")
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}