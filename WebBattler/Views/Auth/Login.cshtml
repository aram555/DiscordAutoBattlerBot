@model WebBattler.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<h1 class="h3 mb-3">Вход</h1>

<form asp-action="Login" method="post" class="card card-body shadow-sm" style="max-width: 420px;">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="DiscordUserId" class="form-label"></label>
        <input asp-for="DiscordUserId" class="form-control" />
        <span asp-validation-for="DiscordUserId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
    <button type="submit" class="btn btn-primary">Войти</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}